# ════════════════════════════════════════════════════════════════════════
#  Distill — Configuration
#  Copy this file to .env and edit as needed.
#  docker compose will read .env automatically.
#
#  Note: Most runtime settings (engine, model, auth, upload limits, etc.)
#  are managed through the Settings UI and stored in the SQLite database.
#  The values below are used to seed the database on the very first run.
#  After that, changes made in the UI take precedence.
# ════════════════════════════════════════════════════════════════════════

# ── Docker Registry ───────────────────────────────────────────────────
# Used by `just release` to push images, and by docker-compose.registry.yml
# to pull pre-built images (for Unraid, etc).
# Examples:
#   ghcr.io/username/whisper-gui
#   docker.io/username/whisper-gui
#   registry.example.com/whisper-gui
DOCKER_REGISTRY=

# Image tag to pull when using docker-compose.registry.yml
# Options: latest, canary, or a specific version (e.g., 2026.03.27)
DOCKER_TAG=latest

# ── Web App ─────────────────────────────────────────────────────────────
# Port exposed on the host machine. Access the UI at http://localhost:<PORT>
APP_PORT=8880


# ── Transcription Engine (initial seed) ────────────────────────────────
# Which engine to use for transcription. Configurable in Settings UI.
# Options:
#   whisper        — OpenAI Whisper (CPU or GPU, pure Python)
#   faster-whisper — Faster-Whisper via CTranslate2 (CPU or GPU, ~4x faster than whisper)
#   canary         — NVIDIA NeMo Canary (GPU only, requires ENABLE_GPU=true)
#   qwen-audio     — Qwen2.5-Audio (GPU only, requires ENABLE_GPU=true)
TRANSCRIPTION_ENGINE=faster-whisper


# ── Whisper / Faster-Whisper Model Size (initial seed) ──────────────────
# Applies when TRANSCRIPTION_ENGINE is "whisper" or "faster-whisper".
# Configurable in Settings UI.
# Options (smallest → largest, fastest → most accurate):
#   tiny, base, small, medium, large-v3, large-v3-turbo
WHISPER_MODEL_SIZE=small


# ── Canary Model (engine=canary) ─────────────────────────────────────────
# Both models require ENABLE_GPU=true.
# Options:
#   nvidia/canary-qwen-2.5b — 2.5B params, ~6 GB VRAM, #1 on OpenASR leaderboard
#   nvidia/canary-1b        — 1B params, English/Spanish/French/German
CANARY_MODEL=nvidia/canary-qwen-2.5b


# ── Qwen Audio Model (engine=qwen-audio) ─────────────────────────────────
# Options:
#   Qwen/Qwen2.5-Audio-3B-Instruct — 3B, ~8 GB VRAM (default, good balance)
#   Qwen/Qwen2.5-Audio-7B-Instruct — 7B, ~16 GB VRAM (higher quality if VRAM allows)
QWEN_MODEL=Qwen/Qwen2.5-Audio-3B-Instruct


# ── Compute Type (faster-whisper only, initial seed) ───────────────────
# CTranslate2 quantization. Configurable in Settings UI.
# Options: int8 (fastest/CPU), int8_float16 (balanced GPU), float16 (best GPU), float32
COMPUTE_TYPE=int8


# ── Language (initial seed) ─────────────────────────────────────────────
# Force a specific language (ISO 639-1). Leave blank for auto-detect.
# Configurable in Settings UI.
LANGUAGE=en


# ── GPU ─────────────────────────────────────────────────────────────────
# Set to true to expose your NVIDIA GPU to the container.
# Requires the nvidia-container-toolkit to be installed on the host:
#   https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/install-guide.html
ENABLE_GPU=false

# Which GPUs to expose. Only used when ENABLE_GPU=true.
# Options: all, 0, 0,1
NVIDIA_VISIBLE_DEVICES=all


# ── Ollama (AI summarization, initial seed) ──────────────────────────────
# URL of your Ollama instance. Configurable in Settings UI.
OLLAMA_URL=http://localhost:11434

# Default Ollama model to use for summarization.
OLLAMA_MODEL=llama3.2


# ── Volumes ───────────────────────────────────────────────────────────────
# Host path where downloaded model weights are stored.
# Models are large (1–15 GB each). Use a persistent location.
MODELS_VOLUME=./volumes/models

# Host path where uploaded audio files are temporarily cached.
AUDIO_CACHE_VOLUME=./volumes/audio_cache

# Host path for the SQLite database and other persistent app data.
DATA_VOLUME=./volumes/data
