<?xml version="1.0"?>
<Container version="2">
  <Name>lumina</Name>
  <Repository>registry.mallen.us/lumina:latest</Repository>
  <Registry>https://registry.mallen.us/</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>

  <Overview>
    Lumina — audio transcription, summarization, and text-to-speech tool. Supports multiple
    transcription engines (faster-whisper, whisper, canary, qwen-audio) with optional GPU
    acceleration. Requires a running Ollama instance for AI summarization.
  </Overview>

  <Category>MediaApp:Music MediaApp:Video Tools:</Category>
  <WebUI>http://[IP]:[PORT:8880]/</WebUI>
  <Icon></Icon>

  <!-- GPU (modern syntax) -->
  <ExtraParams>--gpus all</ExtraParams>

  <!-- ── Ports ───────────────────────────────────────── -->
  <Config
    Name="Web UI Port"
    Target="8000"
    Default="8880"
    Mode="tcp"
    Description="Port to access the Lumina web interface and API."
    Type="Port"
    Display="always"
    Required="true"
    Mask="false">8880</Config>

  <!-- ── Paths ───────────────────────────────────────── -->
  <Config
    Name="Models"
    Target="/models"
    Default="/mnt/user/appdata/lumina/models"
    Mode="rw"
    Description="Persistent storage for downloaded models."
    Type="Path"
    Display="always"
    Required="true">/mnt/user/appdata/lumina/models</Config>

  <Config
    Name="Audio Cache"
    Target="/cache/audio"
    Default="/mnt/user/appdata/lumina/cache"
    Mode="rw"
    Description="Temporary audio file cache."
    Type="Path"
    Display="always"
    Required="true">/mnt/user/appdata/lumina/cache</Config>

  <Config
    Name="App Data"
    Target="/data"
    Default="/mnt/user/appdata/lumina/data"
    Mode="rw"
    Description="Application data: DB, settings."
    Type="Path"
    Display="always"
    Required="true">/mnt/user/appdata/lumina/data</Config>

  <!-- ── Ollama ────────────────────────────────────── -->
  <Config
    Name="Ollama URL"
    Target="OLLAMA_URL"
    Default="http://localhost:11434"
    Type="Variable"
    Display="always"
    Required="true"
    Description="URL of your Ollama instance. Required for AI summarization.">http://localhost:11434</Config>

  <Config
    Name="Ollama Model"
    Target="OLLAMA_MODEL"
    Default="llama3.2"
    Type="Variable"
    Display="always"
    Required="true"
    Description="Ollama model to use for summarization (e.g. llama3.2, mistral, gemma3).">llama3.2</Config>

  <!-- ── Engine ─────────────────────────────────────── -->
  <Config
    Name="Transcription Engine"
    Target="TRANSCRIPTION_ENGINE"
    Default="faster-whisper"
    Type="Variable"
    Display="always">faster-whisper</Config>

  <!-- ── Model ──────────────────────────────────────── -->
  <Config
    Name="Whisper Model Size"
    Target="WHISPER_MODEL_SIZE"
    Default="large-v3-turbo"
    Type="Variable"
    Display="always">large-v3-turbo</Config>

  <Config
    Name="Canary Model"
    Target="CANARY_MODEL"
    Default="nvidia/canary-qwen-2.5b"
    Type="Variable"
    Display="advanced">nvidia/canary-qwen-2.5b</Config>

  <Config
    Name="Qwen Audio Model"
    Target="QWEN_MODEL"
    Default="Qwen/Qwen2.5-Audio-3B-Instruct"
    Type="Variable"
    Display="advanced">Qwen/Qwen2.5-Audio-3B-Instruct</Config>

  <!-- ── Timezone ─────────────────────────────────── -->
  <Config
    Name="Timezone"
    Target="TZ"
    Default="UTC"
    Type="Variable"
    Display="always"
    Required="false"
    Description="Container timezone. Defaults to UTC. Example: America/New_York">UTC</Config>

  <!-- ── Performance ────────────────────────────────── -->
  <Config
    Name="Compute Type"
    Target="COMPUTE_TYPE"
    Default="int8_float16"
    Type="Variable"
    Display="always">int8_float16</Config>

  <Config
    Name="Language"
    Target="LANGUAGE"
    Default="en"
    Type="Variable"
    Display="always">en</Config>

  <!-- ── HuggingFace ───────────────────────────────── -->
  <Config
    Name="HuggingFace Token"
    Target="HF_TOKEN"
    Default=""
    Type="Variable"
    Display="advanced"
    Mask="true"
    Description="Optional. Required for speaker diarization (pyannote.audio). Get a token at huggingface.co/settings/tokens."></Config>

  <!-- ── Text to Speech ────────────────────────────── -->
  <Config
    Name="TTS Enabled"
    Target="TTS_ENABLED"
    Default="true"
    Type="Variable"
    Display="always"
    Description="Enable Kokoro text-to-speech. Download model weights via Settings after first start.">true</Config>

  <Config
    Name="TTS Default Voice"
    Target="TTS_VOICE"
    Default="af_bella"
    Type="Variable"
    Display="advanced"
    Description="Default TTS voice. Options: af_bella, af_nova, af_sarah, am_michael, bm_george, bf_emma, and more. Configure in Settings.">af_bella</Config>

  <!-- ── API ───────────────────────────────────────── -->
  <Config
    Name="API Key"
    Target="API_KEY"
    Default=""
    Type="Variable"
    Display="always"
    Mask="true"></Config>

  <!-- ── Auth ──────────────────────────────────────── -->
  <Config
    Name="Auth Enabled"
    Target="AUTH_ENABLED"
    Default="false"
    Type="Variable"
    Display="always">false</Config>

  <Config
    Name="Auth Username"
    Target="AUTH_USERNAME"
    Default="admin"
    Type="Variable"
    Display="always">admin</Config>

  <Config
    Name="Auth Password"
    Target="AUTH_PASSWORD"
    Default=""
    Type="Variable"
    Display="always"
    Mask="true"></Config>

</Container>
